# =========================================
# Creepy Code .gitignore
# 対象: Java / Spring Boot / Maven / Thymeleaf
# =========================================

# --- Java / Maven ビルド成果物 ---
target/
build/
out/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
hs_err_pid*
replay_pid*

# --- Maven ラッパー関連（必要に応じてコメントアウト） ---
# .mvn/wrapper/maven-wrapper.jar

# --- Spring Boot ---
*.log
logs/
spring.log*
application-local.properties
application-local.yml
application-local.yaml
application-secret.properties
application-secret.yml

# --- 秘密情報 / 環境変数 ---
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
secrets/

# --- IntelliJ IDEA ---
.idea/
*.iml
*.ipr
*.iws

# --- Eclipse / STS ---
.project
.classpath
.settings/
.factorypath
.apt_generated/
.springBeans
.sts4-cache/

# --- VS Code ---
.vscode/
*.code-workspace

# --- NetBeans ---
nbproject/private/
nbbuild/
dist/
nbdist/
.nb-gradle/

# --- OS 依存ファイル ---
# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Linux
*~
.fuse_hidden*
.Trash-*

# --- Claude Code 設定（個人設定は共有しない） ---
.claude/

# --- 一時ファイル / バックアップ ---
*.tmp
*.temp
*.bak
*.swp
*.swo
*~

# --- Node（フロント補助ツールを入れた時用） ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- テスト・カバレッジ ---
.coverage
coverage/
*.cover
.hypothesis/
.pytest_cache/

# --- DB ローカルデータ（Oracle等の一時ファイル） ---
*.dbf
*.ora
*.trc
*.dmp
